# Production: URL of a Modal-hosted axiom-rules-engine service (optional).
# When set, the runtime POSTs to it; when unset, it spawns the local binary.
AXIOM_ENGINE_URL=

# Local dev only — paths to the binary and artifacts dir. Defaults assume the
# layout produced by scripts/setup-engine.sh.
AXIOM_RULES_ENGINE_BINARY=
AXIOM_ARTIFACTS_DIR=
