# Production: URL of the Modal-hosted co-snap-cliffs engine service.
# Set on Vercel after `modal deploy modal_app.py`. When unset the Next.js
# server falls back to spawning the local axiom-rules-engine binary (dev path).
# Example:
#   https://policyengine--co-snap-cliffs-web.modal.run
AXIOM_ENGINE_URL=

# Local dev only — overrides for the binary and artifacts paths produced
# by scripts/setup-engine.sh. Defaults usually work.
AXIOM_RULES_ENGINE_BINARY=
AXIOM_ARTIFACTS_DIR=
